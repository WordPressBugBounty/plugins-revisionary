msgid ""
"If the user can't edit the published post, require Submit Revision "
"capabilities (revise_posts, revise_others_pages, etc.)"
msgstr ""
"Jei vartotojas negali redaguoti paskelbto įrašo, reikia reikalauti Pateikimo "
"Revizijos teises (revise_posts, revise_others_pages ir kt.)"

#: admin/options.php:1460 admin/options.php:1494
#, php-format
msgid "When a %s is published, update post publish date to current time."
msgstr ""
