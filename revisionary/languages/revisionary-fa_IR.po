msgstr "همگام‌سازی پرچم‌های \"نیاز به به‌روزرسانی\""

#: admin/options.php:1961
msgid ""
"Set \"Needs Update\" for any post with translations which was updated "
"(possibly by revision approval) more recently than its translations."
msgstr ""
