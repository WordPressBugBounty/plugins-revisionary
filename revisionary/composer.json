{
  "name": "publishpress/publishpress-revisions",
  "type": "wordpress-plugin",
  "description": "",
  "homepage": "https://publishpress.com/",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "PublishPress",
      "email": "help@publishpress.com"
    },
    {
      "name": "Kevin Behrens",
      "email": "kevin@agapetry.net",
      "homepage": "https://agapetry.net",
      "role": "Lead Developer"
    }
  ],
  "config": {
    "preferred-install": {
      "*": "dist"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true,
      "php-http/discovery": true,
      "publishpress/dev-workspace": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=7.2.5"
  },
  "require-dev": {
    "publishpress/dev-workspace": "dev-testing-translations"
  },
  "scripts": {
      "check:lint": "phplint",
      "check:phpcs": "phpcs",
      "-pre-autoload-dump": "composer dumpautoload --working-dir=./lib",
      "-pre-update-cmd": "composer update --working-dir=./lib",
      "-pre-install-cmd": "composer install --working-dir=./lib",
      "term": "cd dev-workspace && ./run",
      "translate-force": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --force --languages=de_DE,fi,fil,id_ID,ja,ko_KR,nl_NL,ru_RU,yor"
  },
  "extra": {
      "plugin-slug": "revisionary",
      "plugin-name": "publishpress-revisions",
      "plugin-folder": "revisionary",
      "version-constant": "PUBLISHPRESS_REVISIONS_VERSION",
      "plugin-lang-domain": "revisionary",
      "plugin-github-repo": "publishpress/publishpress-revisions",
      "plugin-composer-package": "publishpress/publishpress-revisions"
  }
}
